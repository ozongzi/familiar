# Familiar — optional environment overrides.
# Copy to `.env`, then `docker compose up -d`. None of these are required for a
# basic local run — sane defaults kick in when they're empty.

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# If set and the `users` table is empty on startup, an admin is created
# automatically. Otherwise the first person to register via the web UI becomes
# admin. Password must be ≥ 8 chars.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=change-me-please

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# If left empty, the GitHub login button still renders but won't work — use
# the password form. Create an OAuth App at https://github.com/settings/developers
# with callback URL `<public-url>/api/auth/github/callback`.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# ── Sandbox artifacts directory on the host ───────────────────────────────────
# Per-conversation sandbox workspaces are mounted from here. Default: ./artifacts
# HOST_ARTIFACTS_PATH=/srv/familiar/artifacts

# ── Claude CLI state on the host (optional) ───────────────────────────────────
# If you use Claude Code CLI as a subprocess backend, share its auth state.
# Default: $HOME/.claude
# HOST_CLAUDE_DIR=/home/user/.claude

# ── CORS / reverse proxy (optional) ───────────────────────────────────────────
# Set to the origin the browser hits if you put a reverse proxy in front of
# Familiar on a different host/port. Leave empty for same-origin deployments.
# ALLOWED_ORIGIN=https://familiar.example.com
