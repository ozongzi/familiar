# Fast-deploy variant: copies locally pre-built artifacts into the runtime image.
# Used by `make deploy` (cross-compile locally → rsync → docker compose up --build).
# For a fresh `git clone && docker compose up`, use backend/Dockerfile instead.

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
      ca-certificates curl gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable" \
       > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y docker-ce-cli \
    && curl -fsSL https://claude.ai/install.sh | bash \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.local/bin:${PATH}"
RUN mkdir -p /app/frontend/dist /app/artifacts

COPY backend/familiar /usr/local/bin/familiar
COPY backend/migrations /migrations
COPY frontend/dist /app/frontend/dist

EXPOSE 3000
CMD ["/usr/local/bin/familiar"]
