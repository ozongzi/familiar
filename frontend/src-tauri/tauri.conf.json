{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "familiar",
  "identifier": "app.familiar.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://familiar.fhmmt.games:3000",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Familiar",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["familiar"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/ozongzi/familiar/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCQjlBQzc1NjQ3Njg1QUQKUldTdGhYWmtkYXk1cXp5bU9hcmpNb2pGUk95Zmt1VnNKaXl3ckk3cWFLSi9hamFuSkpKUE1qUWkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "tunnel-bridge.cjs": "tunnel-bridge.cjs",
      "mcp-bundle/": "mcp-bundle/"
    },
    "externalBin": [
      "binaries/node"
    ]
  }
}
