{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "familiar",
  "version": "0.1.0",
  "identifier": "app.familiar.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://familiar.fhmmt.games:3000",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Familiar",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "tunnel-bridge.cjs": "tunnel-bridge.cjs",
      "mcp-bundle/": "mcp-bundle/"
    },
    "externalBin": [
      "binaries/node"
    ]
  }
}
